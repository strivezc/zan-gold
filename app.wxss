/** app.wxss **/
page {
  /* 全局配色变量 - 浅色模式 */
  --bg-color: #f5f6f7;
  --card-white: #ffffff;
  --text-main: #1d1d1f;
  --text-sub: #86868b;

  /* 活力金渐变 */
  --gold-gradient: linear-gradient(135deg, #ff9500 0%, #ffcc00 100%);
  --gold-text: #ff9500;

  /* 科技银渐变 */
  --silver-gradient: linear-gradient(135deg, #8e8e93 0%, #e5e5ea 100%);
  --silver-text: #8e8e93;

  /* 涨跌色 (中国红涨绿跌) */
  --color-up: #ff3b30;
  --color-down: #34c759;

  /* 暗色模式需额外定义的变量 */
  --shadow-card: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  --bg-subtle: rgba(0, 0, 0, 0.03);

  background-color: #f5f6f7;
  color: var(--text-main);
  font-family: -apple-system, "SF Pro Text", "Helvetica Neue", sans-serif;
}

/* 深色模式 */
.dark {
  --bg-color: #000000;
  --card-white: #1c1c1e;
  --text-main: #f5f5f7;
  --text-sub: #98989d;
  --gold-text: #ffb340;
  --silver-text: #aeaeb2;
  --color-up: #ff453a;
  --color-down: #30d158;
  --shadow-card: 0 10rpx 30rpx rgba(0, 0, 0, 0.3);
  --bg-subtle: rgba(255, 255, 255, 0.05);
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background-color: #f5f6f7;
}
.dark.container {
  background-color: #000000;
}
