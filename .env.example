# QQ mailbox config
QQ_EMAIL=your_qq_mail@qq.com
QQ_AUTH_CODE=your_qq_smtp_auth_code
ALERT_TO=receiver_mail@qq.com

# Target domestic gold price range (CNY/gram)
TARGET_MIN_CNY_G=720
TARGET_MAX_CNY_G=740

# Poll schedule (node-cron format)
# */5 * * * *  -> every 5 minutes
CRON_EXPR=*/5 * * * *

# Timezone and repeated-notice cooldown
TZ=Asia/Shanghai
COOLDOWN_MINUTES=60

