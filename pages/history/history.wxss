.container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 0;
  background: var(--bg-color);
}

/* 盈亏汇总 */
.pnl-banner {
  padding: 32rpx;
  border-radius: 28rpx;
  text-align: center;
  margin-bottom: 24rpx;
}
.pnl-banner.up {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff3b30 100%);
  color: #fff;
}
.pnl-banner.down {
  background: linear-gradient(135deg, #51cf66 0%, #34c759 100%);
  color: #fff;
}
.pnl-label {
  font-size: 22rpx;
  font-weight: 600;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}
.pnl-amount {
  font-size: 52rpx;
  font-weight: 900;
  display: block;
  letter-spacing: -1rpx;
}

/* 筛选 */
.filter-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.chip {
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-sub);
  background: var(--card-white);
}
.chip.active {
  color: #fff;
  background: #ff9500;
}

/* 交易列表 */
.tx-list {
  padding-bottom: 120rpx;
}
.tx-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-white);
  border-radius: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}
.tx-type {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.tx-type.buy {
  background: rgba(52, 199, 89, 0.1);
  color: #34c759;
}
.tx-type.sell {
  background: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}
.tx-info { flex: 1; }
.tx-metal {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
}
.tx-detail {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 4rpx;
}
.tx-date {
  font-size: 20rpx;
  color: var(--text-sub);
  opacity: 0.7;
  display: block;
  margin-top: 2rpx;
}
.tx-pnl {
  font-size: 28rpx;
  font-weight: 800;
  text-align: right;
  flex-shrink: 0;
}
.up { color: var(--color-up); }
.down { color: var(--color-down); }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 0;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.empty-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
}
.empty-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 8rpx;
  padding: 0 60rpx;
}

/* 底部安全间距(避免TabBar遮挡) */
.tabbar-safe-bottom {
  height: calc(180rpx + env(safe-area-inset-bottom));
}
