.container {
  min-height: 100vh;
  padding: 0 32rpx;
  padding-bottom: 0;
  display: flex;
  flex-direction: column;
  background: var(--bg-color);
}

/* Header */
.header {
  padding: 30rpx 0 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.brand {
  display: flex;
  align-items: center;
}
.gold-bar-logo {
  width: 32rpx;
  height: 32rpx;
  background: var(--gold-gradient);
  border-radius: 8rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 149, 0, 0.3);
}
.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: -1rpx;
}
.manual-refresh {
  padding: 12rpx 28rpx;
  background: var(--card-white);
  border-radius: 100rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}
.manual-refresh:active {
  transform: scale(0.95);
  opacity: 0.7;
}
.refresh-icon {
  font-size: 24rpx;
  color: var(--text-main);
  margin-right: 8rpx;
  font-weight: bold;
  display: block;
}
.refresh-label {
  font-size: 22rpx;
  color: var(--text-main);
  font-weight: 600;
}
.rotating .refresh-icon {
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 行情卡片 */
.market-view {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
  flex-shrink: 0;
}
.m-card {
  padding: 30rpx;
  border-radius: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.gold-card-wrap { flex: 1.3; }
.silver-card-wrap { flex: 1; }
.gold {
  background: var(--gold-gradient);
  color: #fff;
}
.silver {
  background: var(--card-white);
  color: var(--text-main);
}
.m-title {
  font-size: 20rpx;
  font-weight: 700;
  opacity: 0.9;
  margin-bottom: 12rpx;
}
.silver .m-title { color: var(--text-sub); }
.m-price-row {
  display: flex;
  align-items: baseline;
  white-space: nowrap;
}
.m-price-g {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2rpx;
}
.gold .m-price-g { text-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1); }
.silver .m-price-g { color: var(--text-main); }
.unit {
  font-size: 22rpx;
  margin-left: 6rpx;
  font-weight: 600;
  opacity: 0.8;
}
.silver .unit { color: var(--text-sub); }
.m-sub-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}
.oz-live {
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.85;
}
.silver .oz-live { color: var(--text-sub); }
.trend {
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  line-height: 1;
}
.gold .trend {
  background: rgba(0, 0, 0, 0.15);
  color: #fff;
  backdrop-filter: blur(10px);
}
.silver .trend.up {
  background: rgba(52, 199, 89, 0.1);
  color: #34c759;
}
.silver .trend.down {
  background: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

/* 金银比 */
.ratio-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  margin-bottom: 8rpx;
}
.ratio-label {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 600;
}
.ratio-value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
}

/* 同步提示 */
.sync-hint-container {
  text-align: center;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}
.sync-hint {
  font-size: 20rpx;
  color: var(--text-sub);
  background: var(--bg-subtle, rgba(0, 0, 0, 0.03));
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

/* 换算器 */
.converter-pane {
  flex-shrink: 0;
  background: var(--card-white);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
  padding-bottom: 24rpx;
}
.converter-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.converter-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}
.live-rate-action {
  font-size: 20rpx;
  color: #ff9500;
  font-weight: 600;
  padding: 8rpx 14rpx;
  background: rgba(255, 149, 0, 0.1);
  border-radius: 100rpx;
}
.converter-input-group {
  height: auto;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}
.converter-result-row {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}
.converter-result-label {
  font-size: 22rpx;
  color: var(--text-sub);
}
.converter-result-value {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-main);
}

/* 输入框通用样式 */
.input-group {
  display: flex;
  align-items: center;
  background: var(--bg-color);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  height: 80rpx;
}
.input-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.label {
  font-size: 18rpx;
  color: var(--text-sub);
  margin-bottom: 4rpx;
  font-weight: 500;
}
.cell-input {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  height: 40rpx;
  min-height: 40rpx;
}
.divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 0 24rpx;
}

/* 暗黑模式微调 */
.dark .converter-pane {
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.2);
}
.dark .manual-refresh {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
}
.dark .divider {
  background: rgba(255, 255, 255, 0.1);
}

/* 底部安全间距(避免TabBar遮挡) */
.tabbar-safe-bottom {
  height: calc(180rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
}
