<view class="container">
  <!-- Header -->
  <view class="header">
    <view class="brand">
      <view class="gold-bar-logo"></view>
      <text class="brand-name">ZAN GOLD</text>
    </view>
    <view class="manual-refresh {{loading ? 'rotating' : ''}}" bindtap="refreshPrices">
      <text class="refresh-icon">↻</text>
      <text class="refresh-label">手动同步</text>
    </view>
  </view>

  <!-- 行情板块 -->
  <view class="market-view">
    <view class="m-card gold gold-card-wrap" wx:if="{{prices.gold}}">
      <view class="m-title">国际现货金</view>
      <view class="m-price-row">
        <text class="m-price-g">{{displayGoldPrice}}</text>
        <text class="unit">元/g</text>
      </view>
      <view class="m-sub-info">
        <text class="oz-live">${{prices.gold.price_oz}}/oz</text>
        <view class="trend {{prices.gold.change >= 0 ? 'up' : 'down'}}">{{prices.gold.percent}}</view>
      </view>
    </view>

    <view class="m-card silver silver-card-wrap" wx:if="{{prices.silver}}">
      <view class="m-title">国际现货银</view>
      <view class="m-price-row">
        <text class="m-price-g">{{displaySilverPrice}}</text>
        <text class="unit">元/g</text>
      </view>
      <view class="m-sub-info">
        <text class="oz-live">${{prices.silver.price_oz}}/oz</text>
        <view class="trend {{prices.silver.change >= 0 ? 'up' : 'down'}}">{{prices.silver.percent}}</view>
      </view>
    </view>
  </view>

  <!-- 同步提示 -->
  <view class="sync-hint-container">
    <text class="sync-hint">每30秒自动刷新 · 上次同步 {{lastUpdate}}</text>
  </view>

  <!-- 持仓 Tile (新增盈亏输入区) -->
  <!-- 国际金价换算 -->
  <view class="converter-pane">
    <view class="converter-title-row">
      <text class="converter-title">国际金价换算</text>
      <view class="live-rate-action" bindtap="onUseLiveRate" wx:if="{{prices.exchangeRate}}">
        使用实时汇率
      </view>
    </view>

    <view class="input-group converter-input-group">
      <view class="input-cell">
        <text class="label">国际金价(美元/盎司)</text>
        <input class="cell-input" type="digit" value="{{intlGoldOzInput}}" bindinput="onIntlGoldOzInput" placeholder="例如 3035.20" />
      </view>
      <view class="divider"></view>
      <view class="input-cell">
        <text class="label">汇率(USD/CNY)</text>
        <input class="cell-input" type="digit" value="{{domesticRateInput}}" bindinput="onDomesticRateInput" placeholder="例如 7.23" />
      </view>
    </view>

    <view class="converter-result-row">
      <text class="converter-result-label">国内参考金价</text>
      <text class="converter-result-value">{{domesticGoldResult}} 元/克</text>
    </view>
  </view>

  <view class="assets-pane">
    <!-- 黄金持仓 -->
    <view class="asset-row">
      <view class="row-header">
        <view class="icon-wrap gold-icon">Au</view>
        <view class="row-info">
          <text class="info-title">黄金持仓</text>

          <!-- 盈亏标签 (当有成本价时显示) -->
          <view class="pnl-tag {{goldPnl >= 0 ? 'pnl-up' : 'pnl-down'}}" wx:if="{{goldCost}}">
            <text>{{goldPnl >= 0 ? '+' : ''}}{{goldPnlRate}}%</text>
            <text class="pnl-val"> ({{goldPnl >= 0 ? '+' : ''}}{{goldPnl}})</text>
          </view>
          <view class="pnl-placeholder" wx:else>未设置成本</view>
        </view>
        <view class="row-total">¥{{displayGoldTotal}}</view>
      </view>

      <!-- 双输入区：一行两个框 -->
      <view class="input-group">
        <view class="input-cell">
          <text class="label">持有克数</text>
          <input class="cell-input" type="digit" value="{{goldWeight}}" bindinput="onGoldWeightInput" placeholder="0" />
        </view>
        <view class="divider"></view>
        <view class="input-cell">
          <text class="label">买入均价</text>
          <input class="cell-input" type="digit" value="{{goldCost}}" bindinput="onGoldCostInput" placeholder="输入成本" />
        </view>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="pane-divider"></view>

    <!-- 白银持仓 -->
    <view class="asset-row">
      <view class="row-header">
        <view class="icon-wrap silver-icon">Ag</view>
        <view class="row-info">
          <text class="info-title">白银持仓</text>

          <view class="pnl-tag {{silverPnl >= 0 ? 'pnl-up' : 'pnl-down'}}" wx:if="{{silverCost}}">
            <text>{{silverPnl >= 0 ? '+' : ''}}{{silverPnlRate}}%</text>
            <text class="pnl-val"> ({{silverPnl >= 0 ? '+' : ''}}{{silverPnl}})</text>
          </view>
          <view class="pnl-placeholder" wx:else>未设置成本</view>
        </view>
        <view class="row-total">¥{{displaySilverTotal}}</view>
      </view>

      <view class="input-group">
        <view class="input-cell">
          <text class="label">持有克数</text>
          <input class="cell-input" type="digit" value="{{silverWeight}}" bindinput="onSilverWeightInput" placeholder="0" />
        </view>
        <view class="divider"></view>
        <view class="input-cell">
          <text class="label">买入均价</text>
          <input class="cell-input" type="digit" value="{{silverCost}}" bindinput="onSilverCostInput" placeholder="输入成本" />
        </view>
      </view>
    </view>
  </view>

  <!-- 底部汇总 -->
  <view class="grand-footer">
    <view class="grand-label">资产总净值 / 总盈亏 (CNY)</view>
    <view class="grand-display">
      <text class="cur">¥</text>
      <text class="num">{{displayGrandTotal}}</text>
    </view>

    <!-- 总盈亏展示 -->
    <view class="total-pnl {{totalPnl >= 0 ? 't-up' : 't-down'}}" wx:if="{{goldCost || silverCost}}">
      <text class="pnl-icon">{{totalPnl >= 0 ? '▲' : '▼'}}</text>
      <text>累计盈亏: {{totalPnl >= 0 ? '+' : ''}}{{totalPnl}} 元</text>
    </view>

    <view class="rate-status" wx:if="{{prices.exchangeRate}}">
      参考汇率 <text class="rate-high">{{prices.exchangeRate}}</text>
    </view>
  </view>

</view>
