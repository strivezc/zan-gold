page {
  overflow: hidden;
  background: #f2f2f7;
}

.container {
  height: 100vh;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
}

/* ... (Header & Market View 保持不变) ... */
.header {
  padding: 30rpx 0 20rpx; /* 微调间距 */
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.brand {
  display: flex;
  align-items: center;
}
.gold-bar-logo {
  width: 32rpx;
  height: 32rpx;
  background: var(--gold-gradient);
  border-radius: 8rpx;
  margin-right: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 149, 0, 0.3);
}
.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #1d1d1f;
  letter-spacing: -1rpx;
}

.manual-refresh {
  padding: 12rpx 28rpx;
  background: #ffffff;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
}
.manual-refresh:active {
  transform: scale(0.95);
  background: #f5f5f5;
}
.refresh-icon {
  font-size: 24rpx;
  color: #1d1d1f;
  margin-right: 8rpx;
  font-weight: bold;
  display: block;
}
.refresh-label {
  font-size: 22rpx;
  color: #1d1d1f;
  font-weight: 600;
}
.rotating .refresh-icon {
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  0% {
    transform: rotate(0deg);
  }
  100% {
    transform: rotate(360deg);
  }
}

.market-view {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}
.m-card {
  padding: 30rpx;
  border-radius: 40rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.gold-card-wrap {
  flex: 1.3;
}
.silver-card-wrap {
  flex: 1;
}
.gold {
  background: var(--gold-gradient);
  color: #fff;
}
.silver {
  background: #ffffff;
  color: #1d1d1f;
}
.m-title {
  font-size: 20rpx;
  font-weight: 700;
  opacity: 0.9;
  margin-bottom: 12rpx;
}
.silver .m-title {
  color: #86868b;
}
.m-price-row {
  display: flex;
  align-items: baseline;
  white-space: nowrap;
}
.m-price-g {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2rpx;
}
.gold .m-price-g {
  text-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
}
.silver .m-price-g {
  color: #1d1d1f;
}
.unit {
  font-size: 22rpx;
  margin-left: 6rpx;
  font-weight: 600;
  opacity: 0.8;
}
.silver .unit {
  color: #86868b;
}
.m-sub-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}
.oz-live {
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.85;
}
.silver .oz-live {
  color: #86868b;
}
.trend {
  font-size: 20rpx;
  font-weight: 800;
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
  line-height: 1;
}
.gold .trend {
  background: rgba(0, 0, 0, 0.15);
  color: #fff;
  backdrop-filter: blur(10px);
}
.silver .trend.up {
  background: rgba(52, 199, 89, 0.1);
  color: #34c759;
}
.silver .trend.down {
  background: rgba(255, 59, 48, 0.1);
  color: #ff3b30;
}

.sync-hint-container {
  text-align: center;
  margin-bottom: 24rpx;
  flex-shrink: 0;
}
.sync-hint {
  font-size: 20rpx;
  color: #86868b;
  background: rgba(0, 0, 0, 0.03);
  padding: 6rpx 16rpx;
  border-radius: 100rpx;
}

/* --- 持仓盈亏改造区 --- */
.converter-pane {
  flex-shrink: 0;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.converter-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.converter-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.live-rate-action {
  font-size: 20rpx;
  color: #ff9500;
  font-weight: 600;
  padding: 8rpx 14rpx;
  background: rgba(255, 149, 0, 0.1);
  border-radius: 100rpx;
}

.converter-input-group {
  height: auto;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}

.converter-result-row {
  margin-top: 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.converter-result-label {
  font-size: 22rpx;
  color: #86868b;
}

.converter-result-value {
  font-size: 34rpx;
  font-weight: 800;
  color: #1d1d1f;
}

.assets-pane {
  flex: 1;
  min-height: 0;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  gap: 32rpx; /* 行间距 */
  margin-bottom: 16rpx;
  overflow-y: auto; /* 以防万一内容过多 */
}

.asset-row {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row-header {
  display: flex;
  align-items: center;
}
.icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.gold-icon {
  background: #fff8e6;
  color: #ff9500;
}
.silver-icon {
  background: #f2f2f7;
  color: #8e8e93;
}

.row-info {
  flex: 1;
}
.info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1d1f;
  display: block;
}
.row-total {
  font-size: 32rpx;
  font-weight: 800;
  color: #1d1d1f;
}

/* 盈亏标签 */
.pnl-tag {
  display: inline-flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 700;
  margin-top: 6rpx;
}
.pnl-up {
  color: var(--color-up);
}
.pnl-down {
  color: var(--color-down);
}
.pnl-placeholder {
  font-size: 20rpx;
  color: #c7c7cc;
  margin-top: 6rpx;
}

/* 双输入框组 */
.input-group {
  display: flex;
  align-items: center;
  background: #f5f5f7;
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  height: 80rpx;
}
.input-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.label {
  font-size: 18rpx;
  color: #86868b;
  margin-bottom: 4rpx;
  font-weight: 500;
}
.cell-input {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
  height: 40rpx;
  min-height: 40rpx;
}
.divider {
  width: 2rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.06);
  margin: 0 24rpx;
}
.pane-divider {
  height: 2rpx;
  background: #f5f5f7;
  width: 100%;
}

/* 底部汇总 */
.grand-footer {
  padding: 20rpx 0 50rpx;
  text-align: center;
  flex-shrink: 0;
  margin-top: auto; /* 自动顶到底部 */
}
.grand-label {
  font-size: 22rpx;
  color: #86868b;
  margin-bottom: 0;
  font-weight: 600;
}
.grand-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
}
.cur {
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 8rpx;
  color: #1d1d1f;
}
.num {
  font-size: 100rpx;
  font-weight: 900;
  color: #1d1d1f;
  letter-spacing: -3rpx;
  line-height: 1.1;
}

.total-pnl {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.03);
  margin-top: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
}
.t-up {
  color: var(--color-up);
  background: rgba(255, 59, 48, 0.08);
}
.t-down {
  color: var(--color-down);
  background: rgba(52, 199, 89, 0.08);
}
.pnl-icon {
  margin-right: 8rpx;
  font-size: 18rpx;
}

.rate-status {
  display: inline-flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #86868b;
}
.rate-high {
  color: #1d1d1f;
  font-weight: 700;
  margin-left: 8rpx;
}
