.container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + 140rpx);
  background: var(--bg-color);
}

/* 汇总卡片 */
.summary-cards {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}
.sum-card {
  flex: 1;
  padding: 24rpx;
  border-radius: 28rpx;
  color: #fff;
}
.gold-bg { background: var(--gold-gradient); }
.silver-bg { background: var(--silver-gradient); }
.sum-label {
  font-size: 20rpx;
  font-weight: 700;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}
.sum-value {
  font-size: 40rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 12rpx;
}
.sum-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  font-weight: 600;
  opacity: 0.9;
}
.sum-pnl.up { color: #fff; }
.sum-pnl.down { color: #c8f7c5; }

/* 总计 */
.grand-total {
  text-align: center;
  margin-bottom: 32rpx;
  padding: 20rpx 0;
}
.gt-label {
  font-size: 22rpx;
  color: var(--text-sub);
  font-weight: 600;
  display: block;
}
.gt-value {
  font-size: 72rpx;
  font-weight: 900;
  color: var(--text-main);
  letter-spacing: -2rpx;
  display: block;
  line-height: 1.2;
}
.gt-pnl {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 8rpx;
}
.gt-pnl.up {
  color: var(--color-up);
  background: rgba(255, 59, 48, 0.08);
}
.gt-pnl.down {
  color: var(--color-down);
  background: rgba(52, 199, 89, 0.08);
}

.share-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  margin-top: 12rpx;
  border-radius: 100rpx;
  background: var(--card-white);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
}
.share-btn:active { opacity: 0.7; }

/* 区块标题 */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}
.pos-count {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-sub);
}

/* 持仓列表 */
.position-list {
  margin-bottom: 120rpx;
}
.pos-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--card-white);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
.pos-left {
  margin-right: 20rpx;
}
.pos-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
}
.gold-icon { background: #fff8e6; color: #ff9500; }
.silver-icon { background: #f2f2f7; color: #8e8e93; }
.platinum-icon { background: #f0f0f5; color: #6e6e73; }
.palladium-icon { background: #e8e8ed; color: #636366; }

.dark .silver-icon { background: #2c2c2e; color: #aeaeb2; }
.dark .platinum-icon { background: #2c2c2e; color: #aeaeb2; }
.dark .palladium-icon { background: #2c2c2e; color: #aeaeb2; }

.pos-center { flex: 1; }
.pos-metal {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
}
.pos-detail {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 4rpx;
}
.pos-date {
  font-size: 20rpx;
  color: var(--text-sub);
  opacity: 0.7;
  display: block;
  margin-top: 4rpx;
}
.pos-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  align-items: flex-end;
}
.pos-action {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  font-size: 20rpx;
  font-weight: 600;
}
.pos-action.sell {
  background: rgba(255, 149, 0, 0.1);
  color: #ff9500;
}
.pos-action.delete {
  background: rgba(255, 59, 48, 0.08);
  color: #ff3b30;
}
.pos-action:active { opacity: 0.6; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
}
.empty-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.empty-text {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
}
.empty-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 8rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--gold-gradient);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 149, 0, 0.4);
  z-index: 100;
}
.fab:active { transform: scale(0.9); }
.fab-icon {
  font-size: 52rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 底Sheet */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.sheet-mask.show { opacity: 1; pointer-events: auto; }

.sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--card-white);
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.sheet.show { transform: translateY(0); }

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
}
.sheet-close {
  font-size: 28rpx;
  color: #ff9500;
  font-weight: 600;
}

.form-group { margin-bottom: 32rpx; }
.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.dark .form-row { border-bottom-color: rgba(255, 255, 255, 0.06); }
.form-label {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
}
.form-value {
  font-size: 28rpx;
  color: var(--text-sub);
  font-weight: 600;
}
.form-input {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  text-align: right;
  width: 300rpx;
}

.sheet-btn {
  background: var(--gold-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
}
.sheet-btn:active { opacity: 0.8; }
.sell-btn {
  background: linear-gradient(135deg, #ff3b30 0%, #ff6b6b 100%);
}

/* 次级汇总卡片(铂金/钯金) */
.secondary {
  margin-top: -12rpx;
}
.platinum-bg { background: linear-gradient(135deg, #6e6e73 0%, #a8a8ad 100%); }
.palladium-bg { background: linear-gradient(135deg, #636366 0%, #8e8e93 100%); }
