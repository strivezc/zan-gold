<view class="container {{isDark ? 'dark' : ''}}">
  <!-- 汇总卡片 -->
  <view class="summary-cards" wx:if="{{summary}}">
    <view class="sum-card gold-bg">
      <text class="sum-label">Au 黄金</text>
      <text class="sum-value">¥{{summary.gold._value}}</text>
      <view class="sum-meta">
        <text>{{summary.gold._weight}}g</text>
        <text class="sum-pnl {{summary.gold.pnl >= 0 ? 'up' : 'down'}}">
          {{summary.gold._pnlRate}}%
        </text>
      </view>
    </view>
    <view class="sum-card silver-bg">
      <text class="sum-label">Ag 白银</text>
      <text class="sum-value">¥{{summary.silver._value}}</text>
      <view class="sum-meta">
        <text>{{summary.silver._weight}}g</text>
        <text class="sum-pnl {{summary.silver.pnl >= 0 ? 'up' : 'down'}}">
          {{summary.silver._pnlRate}}%
        </text>
      </view>
    </view>
  </view>

  <!-- 铂金/钯金汇总(有持仓时显示) -->
  <view class="summary-cards secondary" wx:if="{{summary.platinum.weight > 0 || summary.palladium.weight > 0}}">
    <view class="sum-card platinum-bg" wx:if="{{summary.platinum.weight > 0}}">
      <text class="sum-label">Pt 铂金</text>
      <text class="sum-value">¥{{summary.platinum._value}}</text>
      <view class="sum-meta">
        <text>{{summary.platinum._weight}}g</text>
        <text class="sum-pnl {{summary.platinum.pnl >= 0 ? 'up' : 'down'}}">
          {{summary.platinum._pnlRate}}%
        </text>
      </view>
    </view>
    <view class="sum-card palladium-bg" wx:if="{{summary.palladium.weight > 0}}">
      <text class="sum-label">Pd 钯金</text>
      <text class="sum-value">¥{{summary.palladium._value}}</text>
      <view class="sum-meta">
        <text>{{summary.palladium._weight}}g</text>
        <text class="sum-pnl {{summary.palladium.pnl >= 0 ? 'up' : 'down'}}">
          {{summary.palladium._pnlRate}}%
        </text>
      </view>
    </view>
  </view>

  <!-- 总计 -->
  <view class="grand-total" wx:if="{{summary}}">
    <text class="gt-label">资产总净值</text>
    <text class="gt-value">¥{{summary._grandTotal}}</text>
    <view class="gt-pnl {{summary.totalPnl >= 0 ? 'up' : 'down'}}" wx:if="{{positions.length > 0}}">
      <text>{{summary.totalPnl >= 0 ? '▲' : '▼'}}</text>
      <text> 累计盈亏: {{summary._totalPnl}} 元</text>
    </view>
    <view class="share-btn" bindtap="onSharePortfolio">
      <text>分享持仓</text>
    </view>
  </view>

  <!-- 持仓列表 -->
  <view class="section-title">
    <text>持仓明细</text>
    <text class="pos-count">共 {{positions.length}} 笔</text>
  </view>

  <view class="position-list">
    <view class="pos-item" wx:for="{{positions}}" wx:key="id">
      <view class="pos-left">
        <view class="pos-icon {{item.metal}}-icon">{{metalIcons[item.metal]}}</view>
      </view>
      <view class="pos-center">
        <text class="pos-metal">{{metalNames[item.metal]}}</text>
        <text class="pos-detail">{{item._weight}}g · 均价 ¥{{item._price}}</text>
        <text class="pos-date">{{item._date}}</text>
      </view>
      <view class="pos-actions">
        <view class="pos-action edit" bindtap="onShowEditSheet" data-id="{{item.id}}">
          <text>编辑</text>
        </view>
        <view class="pos-action sell" bindtap="onShowSellSheet" data-metal="{{item.metal}}">
          <text>卖出</text>
        </view>
        <view class="pos-action delete" bindtap="onDeletePosition" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{positions.length === 0}}">
      <text class="empty-icon">📊</text>
      <text class="empty-text">暂无持仓记录</text>
      <text class="empty-hint">点击下方按钮添加你的第一笔持仓</text>
    </view>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bindtap="onShowAddSheet">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加持仓底Sheet -->
  <view class="sheet-mask {{showAddSheet ? 'show' : ''}}" bindtap="onHideAddSheet"></view>
  <view class="sheet {{showAddSheet ? 'show' : ''}}">
    <view class="sheet-header">
      <text class="sheet-title">买入建仓</text>
      <text class="sheet-close" bindtap="onHideAddSheet">取消</text>
    </view>
    <view class="form-group">
      <view class="form-row">
        <text class="form-label">金属类型</text>
        <picker range="{{['黄金', '白银', '铂金', '钯金']}}" bindchange="onMetalChange">
          <text class="form-value">{{metalNames[newMetal]}} ▾</text>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">买入日期</text>
        <picker mode="date" value="{{newDate}}" bindchange="onDateChange">
          <text class="form-value">{{newDate}} ▾</text>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">买入均价 (元/g)</text>
        <input class="form-input" type="digit" value="{{newPrice}}" bindinput="onNewPriceInput" placeholder="输入买入价格" />
      </view>
      <view class="form-row">
        <text class="form-label">持有克数</text>
        <input class="form-input" type="digit" value="{{newWeight}}" bindinput="onNewWeightInput" placeholder="输入克数" />
      </view>
      <view class="form-row">
        <text class="form-label">备注 (可选)</text>
        <input class="form-input" value="{{newNote}}" bindinput="onNewNoteInput" placeholder="如: 春节购入" />
      </view>
    </view>
    <view class="sheet-btn" bindtap="onConfirmAdd">确认买入</view>
  </view>

  <!-- 卖出底Sheet -->
  <view class="sheet-mask {{showSellSheet ? 'show' : ''}}" bindtap="onHideSellSheet"></view>
  <view class="sheet {{showSellSheet ? 'show' : ''}}">
    <view class="sheet-header">
      <text class="sheet-title">卖出{{metalNames[sellMetal]}}</text>
      <text class="sheet-close" bindtap="onHideSellSheet">取消</text>
    </view>
    <view class="form-group">
      <view class="form-row">
        <text class="form-label">可卖克数</text>
        <text class="form-value">{{sellAvailableStr}}g</text>
      </view>
      <view class="form-row">
        <text class="form-label">卖出克数</text>
        <input class="form-input" type="digit" value="{{sellWeight}}" bindinput="onSellWeightInput" placeholder="输入卖出克数" />
      </view>
      <view class="form-row">
        <text class="form-label">卖出价格 (元/g)</text>
        <input class="form-input" type="digit" value="{{sellPrice}}" bindinput="onSellPriceInput" placeholder="输入卖出价格" />
      </view>
    </view>
    <view class="sheet-btn sell-btn" bindtap="onConfirmSell">确认卖出</view>
  </view>

  <!-- 编辑持仓底Sheet -->
  <view class="sheet-mask {{showEditSheet ? 'show' : ''}}" bindtap="onHideEditSheet"></view>
  <view class="sheet {{showEditSheet ? 'show' : ''}}">
    <view class="sheet-header">
      <text class="sheet-title">编辑持仓</text>
      <text class="sheet-close" bindtap="onHideEditSheet">取消</text>
    </view>
    <view class="form-group">
      <view class="form-row">
        <text class="form-label">金属类型</text>
        <picker range="{{['黄金', '白银', '铂金', '钯金']}}" bindchange="onEditMetalChange">
          <text class="form-value">{{metalNames[editMetal]}} ▾</text>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">买入日期</text>
        <picker mode="date" value="{{editDate}}" bindchange="onEditDateChange">
          <text class="form-value">{{editDate}} ▾</text>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">买入均价 (元/g)</text>
        <input class="form-input" type="digit" value="{{editPrice}}" bindinput="onEditPriceInput" placeholder="输入买入价格" />
      </view>
      <view class="form-row">
        <text class="form-label">持有克数</text>
        <input class="form-input" type="digit" value="{{editWeight}}" bindinput="onEditWeightInput" placeholder="输入克数" />
      </view>
      <view class="form-row">
        <text class="form-label">备注 (可选)</text>
        <input class="form-input" value="{{editNote}}" bindinput="onEditNoteInput" placeholder="如: 春节购入" />
      </view>
    </view>
    <view class="sheet-btn" bindtap="onConfirmEdit">保存修改</view>
  </view>

  <!-- 底部安全间距 -->
  <view class="tabbar-safe-bottom"></view>
</view>
