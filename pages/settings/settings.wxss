.container {
  min-height: 100vh;
  padding: 24rpx 32rpx;
  padding-bottom: 0;
  background: var(--bg-color);
}

.section {
  margin-bottom: 40rpx;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-sub);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  padding-left: 8rpx;
}
.add-btn {
  padding: 8rpx 24rpx;
  background: rgba(255, 149, 0, 0.1);
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #ff9500;
}

/* 主题选择器 */
.theme-picker {
  display: flex;
  gap: 16rpx;
  background: var(--card-white);
  border-radius: 24rpx;
  padding: 12rpx;
}
.theme-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  transition: all 0.2s;
}
.theme-option.active {
  background: rgba(255, 149, 0, 0.1);
}
.theme-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.dark .theme-icon {
  color: #ffffff;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.5);
}
.theme-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
}
.theme-option.active .theme-label {
  color: #ff9500;
}

/* 预警项 */
.alert-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--card-white);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}
.alert-info {}
.alert-metal {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  display: block;
}
.alert-condition {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 4rpx;
}
.alert-status {
  font-size: 20rpx;
  display: block;
  margin-top: 4rpx;
}
.alert-status.pending { color: var(--text-sub); }
.alert-status.triggered { color: #34c759; }
.alert-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.alert-switch {
  transform: scale(0.8);
}
.alert-delete {
  font-size: 22rpx;
  color: #ff3b30;
  font-weight: 600;
  padding: 8rpx;
}

.empty-alerts {
  text-align: center;
  padding: 40rpx 0;
  background: var(--card-white);
  border-radius: 20rpx;
}
.empty-alerts .empty-text {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
}
.empty-alerts .empty-hint {
  font-size: 20rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 8rpx;
}

/* 设置项 */
.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  background: var(--card-white);
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}
.setting-item:active {
  opacity: 0.7;
}
.item-left {
  display: flex;
  align-items: center;
}
.item-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}
.dark .item-icon {
  color: #ffffff;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.5);
}
.item-info {}
.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  display: block;
}
.item-desc {
  font-size: 22rpx;
  color: var(--text-sub);
  display: block;
  margin-top: 4rpx;
}
.item-arrow {
  font-size: 36rpx;
  color: var(--text-sub);
  font-weight: 300;
}
.danger .item-title {
  color: #ff3b30;
}

/* 底Sheet */
.sheet-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}
.sheet-mask.show { opacity: 1; pointer-events: auto; }

.sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: var(--card-white);
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + 120rpx + env(safe-area-inset-bottom));
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}
.sheet.show { transform: translateY(0); }

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.sheet-title {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
}
.sheet-close {
  font-size: 28rpx;
  color: #ff9500;
  font-weight: 600;
}

.form-group { margin-bottom: 32rpx; max-height: 60vh; overflow-y: auto; }
.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}
.dark .form-row { border-bottom-color: rgba(255, 255, 255, 0.06); }
.form-label {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 500;
}
.form-value {
  font-size: 28rpx;
  color: var(--text-sub);
  font-weight: 600;
}
.form-input {
  font-size: 28rpx;
  color: var(--text-main);
  font-weight: 600;
  text-align: right;
  width: 300rpx;
}

.sheet-btn {
  background: var(--gold-gradient);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
}
.sheet-btn:active { opacity: 0.8; }

/* 底部安全间距(避免TabBar遮挡) */
.tabbar-safe-bottom {
  height: calc(180rpx + env(safe-area-inset-bottom));
}
