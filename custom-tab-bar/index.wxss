.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 120rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
}

/* 深色模式 */
.tab-bar.dark {
  background: rgba(28, 28, 30, 0.95) !important;
  border-top-color: rgba(255, 255, 255, 0.1);
}
.tab-bar.dark .tab-icon {
  opacity: 1;
  color: #ffffff;
  text-shadow: 0 0 4rpx rgba(255, 255, 255, 0.5);
}
.tab-bar.dark .tab-label { color: #e5e5ea; }

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  position: relative;
  padding-top: 8rpx;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  opacity: 0.5;
  transition: opacity 0.2s;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #86868b;
  transition: color 0.2s;
}

.tab-item.active .tab-label {
  color: #ff9500;
}

.tab-indicator {
  width: 40rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #ff9500;
  margin-top: 6rpx;
}
