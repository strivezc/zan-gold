.chart-container {
  background: var(--card-white);
  border-radius: 28rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.chart-tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}
.tab {
  padding: 8rpx 28rpx;
  border-radius: 100rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-sub);
  transition: all 0.2s;
}
.tab.active {
  color: #fff;
  background: #ff9500;
}

.chart-area {
  position: relative;
}
.chart-canvas {
  width: 100%;
  height: 400rpx;
}

.chart-info {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  background: rgba(0, 0, 0, 0.6);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
}
.chart-time {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
}
.chart-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}
